{
  "name": "@adi/checkout-widget",
  "version": "0.1.0",
  "description": "ADIPay — embeddable merchant checkout widget with QR + token swap for ADI Chain",
  "type": "module",
  "main": "./dist/adipay.cjs",
  "module": "./dist/adipay.js",
  "browser": "./dist/adipay.global.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/adipay.js",
      "require": "./dist/adipay.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs,iife --global-name ADIPay --dts --clean --out-dir dist",
    "dev": "tsup src/index.ts --format esm,cjs,iife --global-name ADIPay --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "viem": "^2.21.19"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
