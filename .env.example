# ADI Testnet
ADI_RPC_URL=https://rpc.ab.testnet.adifoundation.ai/
CHAIN_ID=99999

# Deployer private key (never commit real keys)
PRIVATE_KEY=0x...

# Track 2: Sponsor service signing key (different from deployer)
SPONSOR_PRIVATE_KEY=0x...

# Oracle private key — used server-side by /api/attest to sign invoice attestations
# Must match the trustedOracle address set in InvoiceZKVerifier
# For local anvil: Anvil account #2 (address 0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC)
ORACLE_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# IdentityRegistry contract address — used server-side by /api/register-sme
# Set to the address output by 01_DeployIdentity.s.sol
IDENTITY_REGISTRY_ADDRESS=0x...

# Public contract addresses — used client-side for SME dashboard
# Set from the deployment broadcast outputs
NEXT_PUBLIC_JUNIOR_TOKEN_ADDRESS=0x...
NEXT_PUBLIC_IDENTITY_REGISTRY_ADDRESS=0x...

# AA Stack (from 04_DeployAA.s.sol output)
NEXT_PUBLIC_ENTRY_POINT_ADDRESS=0x...
NEXT_PUBLIC_PAYMASTER_ADDRESS=0x...
NEXT_PUBLIC_ERC20_PAYMASTER_ADDRESS=0x...
NEXT_PUBLIC_SMART_ACCOUNT_FACTORY_ADDRESS=0x...

# Block explorer API key (for contract verification)
ETHERSCAN_API_KEY=

# Admin address (receives admin roles)
ADMIN_ADDRESS=0x...
